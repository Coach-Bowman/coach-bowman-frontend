---
import Container from "./Container.astro";
import beam from "../assets/beam-tripod.png";
---

<div class="relative" id="home">
  <div
    aria-hidden="true"
    class="absolute inset-0 grid grid-cols-2 -space-x-52 opacity-30 dark:opacity-50"
  >
    <div class="blur-[106px] h-56 bg-gradient-to-br from-primary to-purple-400">
    </div>
    <div class="blur-[106px] h-32 bg-gradient-to-r from-cyan-400 to-sky-300">
    </div>
  </div>
  <Container>
    <div class="pt-10 ml-auto">
      <section class="bg-white dark:bg-gray-900">
        <div
          class="relative py-8 px-4 mx-auto max-w-screen-xl lg:py-16 lg:px-6"
        >
          <div class="text-center mx-auto mb-8">
            <h1
              class="text-gray-900 dark:text-white font-bold text-5xl md:text-6xl xl:text-6xl"
            >
              Users
            </h1>
            <p
              class="mt-8 text-center text-xl text-gray-600 dark:text-gray-300"
            >
              A list of users fetched from the API.
            </p>
          </div>
          <!-- User Table -->
          <div
            class="group p-6 sm:p-8 rounded-3xl bg-white border border-gray-100 dark:shadow-none dark:border-gray-700 dark:bg-gray-800 shadow-2xl shadow-gray-600/10 max-w-auto mx-auto"
          >
            <div class="overflow-x-auto">
              <table
                class="table-auto w-full text-left text-gray-900 dark:text-gray-200"
              >
                <thead>
                  <tr>
                    <th class="px-4 py-2 border-b dark:border-gray-700">ID</th>
                    <th class="px-4 py-2 border-b dark:border-gray-700">Name</th
                    >
                    <th class="px-4 py-2 border-b dark:border-gray-700"
                      >Email</th
                    >
                    <th class="px-4 py-2 border-b dark:border-gray-700"
                      >Sport</th
                    >
                    <th class="px-4 py-2 border-b dark:border-gray-700">Date</th
                    >
                  </tr>
                </thead>
                <tbody id="user-table-body">
                  <!-- Rows will be dynamically populated here -->
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </section>
    </div>
  </Container>
</div>

<script type="module">
  async function fetchUsers() {
    const tableBody = document.getElementById("user-table-body");
    const apiUrl = "/api/users";

    try {
      const response = await fetch(apiUrl);
      if (!response.ok) {
        throw new Error(`HTTP error! status: ${response.status}`);
      }

      const users = await response.json();
      if (users.length > 0) {
        tableBody.innerHTML = users
          .map(
            (user) => `
            <tr class="hover:bg-gray-100 dark:hover:bg-gray-700">
              <td class="px-4 py-2 border-b dark:border-gray-700">${user.id}</td>
              <td class="px-4 py-2 border-b dark:border-gray-700">${user.name}</td>
              <td class="px-4 py-2 border-b dark:border-gray-700">${user.email}</td>
              <td class="px-4 py-2 border-b dark:border-gray-700">${user.sport}</td>
              <td class="px-4 py-2 border-b dark:border-gray-700">${user.formattedDate}</td>
            </tr>
          `,
          )
          .join("");
      } else {
        tableBody.innerHTML = `
          <tr>
            <td colspan="5" class="text-center text-gray-600 dark:text-gray-400 py-4">
              No users found.
            </td>
          </tr>
        `;
      }
    } catch (error) {
      tableBody.innerHTML = `
        <tr>
          <td colspan="5" class="text-center text-gray-600 dark:text-gray-400 py-4">
            Failed to load users.
          </td>
        </tr>
      `;
      console.error(error);
    }
  }

  document.addEventListener("DOMContentLoaded", fetchUsers);
</script>
