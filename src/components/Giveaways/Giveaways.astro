---
import Container from "../Container.astro";
import unconnected_tripod from "../../assets/unconnected-tripod.png";
import beam from "../../assets/SOPHIE-BEAM.png";
import stickCellyVideoLight from "../../assets/sikra-stick-celly-light.mp4";
import stickCellyVideoDark from "../../assets/sikra-stick-celly-dark.mp4";
import clippingVideoLight from "../../assets/sikra-clipping-light.mp4";
import clippingVideoDark from "../../assets/sikra-clipping-dark.mp4";
import prizes from "../../assets/prizes.png";
import question_mark from "../../assets/question_mark.jpg";

---

<div id="features">
  <!-- <Container> -->
  <div class="mx-10 mt-10 lg:my-10 lg:ml-32 lg:mr-10">
    <div
      class="space-y-6 justify-between text-gray-600 md:flex md:gap-6 md:space-y-0 lg:gap-4 "
    >
      <div class="md:w-1/2">
          <p
            class="mt-8 mb-0 text-center text-gray-900 dark:text-white font-bold text-4xl md:text-5xl xl:text-5xl"
          >Chance to Win a
            <span
              class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 font-bold text-4xl md:text-5xl xl:text-5xl"
            >
              ~$250 Prize Pack
            </span>
          </p>
          <p class="mt-8 mb-8 text-center text-lg text-gray-600 dark:text-gray-300">
          Exclusive Coach Bowman Training Tank, Tripod, One Year Coach Bowman Subscription, and a $100 Amazon Giftcard.
        </p>
          <img
            src={prizes}
            alt="dashboard screenshot"
            class="mx-auto mt-0 w-full max-w-2xl md:mt-0"
          />
        </div>
      <div class="md:w-1/2">
          <p
            class="mt-8 mb-0 text-center text-gray-900 dark:text-white font-bold text-4xl md:text-5xl xl:text-5xl"
          >
            <span
              class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 font-bold text-4xl md:text-5xl xl:text-5xl"
            >
              Stick
            </span> 
            a Dismount, Hit a 
            <span
              class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 font-bold text-4xl md:text-5xl xl:text-5xl"
            >
              Celly. 
            </span> 
            
            
          </p>
         <p class="mt-8 mb-8 text-center text-lg text-gray-600 dark:text-gray-300">
            Capture a stuck dismount followed by your favorite celebration using the Coach Bowman app. Want to stand out? Add your favorite skills before the dismount. 
        </p>
          <video
          class="mx-auto w-full max-w-2xl dark:hidden"
          src={stickCellyVideoLight}
          autoplay
          loop
          muted
          playsinline
        ></video>
        <video
          class="mx-auto hidden w-full max-w-2xl dark:block"
          src={stickCellyVideoDark}
          autoplay
          loop
          muted
          playsinline
        ></video>
        </div>
        </div>
        <div class="mx-auto py-8 border-y border-gray-100 dark:border-gray-800 mt-6 w-full max-w-5xl">
          <p
            id="giveaway-progress-label"
            class="mb-24 text-center text-gray-900 dark:text-white font-bold text-4xl md:text-5xl xl:text-6xl md:mb-32"
          >
            <span id="giveaway-progress-text">Two New Winners in </span>
            <span
              id="giveaway-progress-highlight"
              class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 font-bold text-4xl md:text-5xl xl:text-6xl"
            >
              0 Days
            </span>
          </p>
          <div class="relative h-3 overflow-visible rounded-full bg-gray-200 dark:bg-gray-700">
            <div
              id="giveaway-progress-fill"
              class="h-full rounded-full bg-primary transition-all duration-500"
              style="width: 0%;"
            >
            </div>
            <div
              id="giveaway-progress-points"
              class="absolute inset-0"
              data-question-mark={question_mark}
            ></div>
          </div>
           <div
            class="mt-2 flex items-center justify-between text-sm text-gray-600 dark:text-gray-300"
          >
          </div>
        </div>
        
    <div
      class="space-y-6 justify-between text-gray-600 md:flex flex-row-reverse md:gap-6 md:space-y-0 lg:gap-4 lg:items-center"
    >
      
      
    </div>
  </div>
  <div class="m-10 lg:my-10 lg:mr-32 lg:ml-10">
    <div
      class="space-y-6 justify-between text-gray-600 md:flex flex-row-reverse md:gap-6 md:space-y-0 lg:gap-10 lg:items-center"
    >
      <div class="md:w-7/12 lg:w-1/2">
        <h2
          class="text-3xl font-bold text-gray-900 md:text-4xl xl:text-5xl dark:text-white text-center"
        >How to Enter the
          <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 font-bold"
            >#CoachBowmanContest</span
          >
        </h2>
        <div class="divide-y space-y-4 divide-gray-100 dark:divide-gray-800">
          <div class="mt-8 flex gap-4 md:items-center">
            <div
              class="w-12 h-12 flex gap-4 rounded-full bg-green-200 dark:bg-green-900/20"
            >
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 m-auto text-green-600 dark:text-green-400">
                <path d="M14 3H7a2 2 0 00-2 2v14a2 2 0 002 2h10a2 2 0 002-2V8z"></path>
                <path d="M14 3v5h5"></path>
                <path d="M9 15l6-6 2 2-6 6-3 1z"></path>
              </svg>
            </div>
            <div class="w-5/6">
              <h4
                class="font-semibold text-lg text-gray-700 dark:text-green-400"
              >
                Step 1: Submit the Official Entry Form (Bottom of this page)
              </h4>
              <p class="text-gray-500 dark:text-gray-400">
                Submissions will only be accepted if the Official Entry Form has been completed and submitted below.
              </p>
            </div>
          </div>
          <div class="pt-4 flex gap-4 md:items-center">
            <div
              class="w-12 h-12 flex gap-4 rounded-full bg-sky-200 dark:bg-sky-900/30"
            >
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 m-auto text-sky-700 dark:text-sky-400">
                <path d="M12 3v12"></path>
                <path d="M8 11l4 4 4-4"></path>
                <rect x="4" y="18" width="16" height="3" rx="1.5"></rect>
              </svg>
            </div>
            <div class="w-5/6">
              <h4
                class="font-semibold text-lg text-gray-700 dark:text-sky-400"
              >
                Step 2: Download the Coach Bowman App
              </h4>
              <p class="text-gray-500 dark:text-gray-400">
                All submission must be captured using the Coach Bowman App. 
               The Coach Bowman app is free to use. No payment is required to qualify for this contest. 
              </p>
            </div>
          </div>
          <div class="pt-4 flex gap-4 md:items-center">
            <div
              class="w-12 h-12 flex items-center justify-center gap-4 rounded-full bg-blue-200 dark:bg-blue-900/20"
            >
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 m-auto text-blue-700 dark:text-blue-400">
                <rect x="4" y="5" width="16" height="10" rx="2"></rect>
                <path d="M8 15l-2 4"></path>
                <path d="M16 15l2 4"></path>
                <circle cx="9" cy="10" r="1.5"></circle>
                <circle cx="15" cy="10" r="1.5"></circle>
              </svg>
            </div>
            <div class="w-5/6">
              <h4
                class="font-semibold text-lg text-gray-700 dark:text-blue-400"
              >
                Step 3: Capture Your Clip in the Coach Bowman App
              </h4>
              <p class="text-gray-500 dark:text-gray-400">
                Submissions videos must include the Coach Bowman watermark that the app generates. Use the #CoachBowmanContest button while clipping. This will add
                the required overlay.
              </p>
            </div>
          </div>
          <div class="pt-4 flex gap-4 md:items-center">
            <div
              class="w-12 h-12 flex items-center justify-center gap-4 rounded-full bg-purple-200 dark:bg-purple-900/20"
            >
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-purple-600 dark:text-purple-400 translate-x-[1px]">
                <circle cx="9" cy="8" r="3"></circle>
                <path d="M2 20c0-3.314 3.134-6 7-6"></path>
                <path d="M16 11v4"></path>
                <path d="M14 13h4"></path>
              </svg>
            </div>
            <div class="w-5/6">
              <h4
                class="font-semibold text-lg text-gray-700 dark:text-purple-400"
              >
                Step 4: Post on Instagram, Tag @coach.bowman.app, and Hashtag #CoachBowmanContest
              </h4>
              <p class="text-gray-500 dark:text-gray-400">
                Post your clip as a Reel, tag @coach.bowman.app, and include
                #CoachBowmanContest to complete your entry.
              </p>
            </div>
          </div>
        </div>
      </div>
      <div class="md:w-5/12 lg:w-1/2">
        <video
          class="mx-auto mt-12 w-full max-w-2xl dark:hidden md:mt-0"
          src={clippingVideoLight}
          autoplay
          loop
          muted
          playsinline
        ></video>
        <video
          class="mx-auto mt-12 hidden w-full max-w-2xl dark:block md:mt-0"
          src={clippingVideoDark}
          autoplay
          loop
          muted
          playsinline
        ></video>
      </div>
    </div>
  </div>
  <div class="m-10 lg:my-10 lg:ml-32 lg:mr-10">
    <div
      class="space-y-6 justify-between text-gray-600 md:flex flex-row-reverse md:gap-6 md:space-y-0 lg:gap-4 lg:items-center"
    >
     
      <div class="max-w-3xl mx-auto">
        <h2
          class="text-3xl font-bold text-gray-900 md:text-4xl dark:text-white"
        > Additional Information 
         
        </h2>
        <div class="divide-y space-y-4 divide-gray-100 dark:divide-gray-800">
          <div class="pt-8 flex gap-4 md:items-center">
            <div
              class="w-12 h-12 flex gap-4 rounded-full bg-blue-200 dark:bg-blue-900/20"
            >
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 m-auto text-blue-700 dark:text-blue-400">
                <rect x="3" y="6" width="10" height="12" rx="2"></rect>
                <rect x="7" y="3" width="10" height="12" rx="2"></rect>
                <path d="M19 15v6"></path>
                <path d="M16 18h6"></path>
              </svg>
            </div>
            <div class="w-5/6">
              <h4
                class="font-semibold text-lg text-gray-700 dark:text-blue-400"
              >
                Multiple Submissions
              </h4>
              <p class="text-gray-500 dark:text-gray-400">
                Participants may submit an unlimited number of unique entries up to the last drawing in May. Once submitted, each entry remains eligible for every drawing that occurs later in that month.
              </p>
            </div>
          </div>

          <div class="pt-4 flex gap-4 md:items-center">
            
            <div
              class="w-12 h-12 flex gap-4 rounded-full bg-green-100 dark:bg-green-900/20"
            >
              <div
                class="w-12 h-12 flex gap-4 rounded-full bg-green-100 dark:bg-green-900/20"
              >
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 m-auto text-green-600 dark:text-green-400">
                  <rect x="7" y="4" width="10" height="16" rx="2"></rect>
                  <path d="M9 4h6v3H9z"></path>
                  <path d="M8.5 13.5l2 2 4-4"></path>
                </svg>
              </div>
            </div>
            <div class="w-5/6">
              <h4
                class="font-semibold text-lg text-gray-700 dark:text-green-400"
              >
                How Winners Are Picked
              </h4>
              <p class="text-gray-500 dark:text-gray-400">
                We pick the most creative, funny, or unique entries. It is
                not about the hardest skill or highest score. 
              </p>
            </div>
          </div>
          <div class="pt-4 flex gap-4 md:items-center">
            <div
              class="w-12 h-12 flex gap-4 rounded-full bg-purple-200 dark:bg-purple-900/20"
            >
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 m-auto text-purple-600 dark:text-purple-400">
                <rect x="7" y="2" width="10" height="20" rx="2"></rect>
                <rect x="10" y="18" width="4" height="1" rx="0.5"></rect>
              </svg>
            </div>
            <div class="w-5/6">
              <h4
                class="font-semibold text-lg text-gray-700 dark:text-purple-400"
              >
                How We Will Contact Winners
              </h4>
              <p class="text-gray-500 dark:text-gray-400">
                Winners will be messaged on Instagram. Be sure to follow @coach.bowman.app and have your DMs open. Winners are expected to respond within 48 hours to claim their prizes, and provide a photo for the winner announcement posts. If a winner does not respond within 48 hours, an alternate winner will be selected.
              </p>
            </div>
          </div>
         
        </div>
      </div>
    </div>
  </div>
</div>


<script>
  const progressFillElement = document.getElementById("giveaway-progress-fill");
  const progressPointsElement = document.getElementById("giveaway-progress-points");
  const progressLabelElement = document.getElementById("giveaway-progress-label");
  const progressLabelTextElement = document.getElementById("giveaway-progress-text");
  const progressLabelHighlightElement = document.getElementById("giveaway-progress-highlight");
  const MANUAL_TEST_DATE = "";
  // const MANUAL_TEST_DATE = "2026-05-31T12:00:00";
  const getNow = () => (MANUAL_TEST_DATE ? new Date(MANUAL_TEST_DATE) : new Date());
  const questionMarkImage = progressPointsElement?.dataset.questionMark || "";

  if (
    progressFillElement &&
    progressPointsElement &&
    progressLabelElement &&
    progressLabelTextElement &&
    progressLabelHighlightElement
  ) {
    const getChallengeYear = () => {
      const now = getNow();
      const currentYear = now.getFullYear();
      const mayEnd = new Date(currentYear, 4, 31, 23, 59, 59, 999);
      return now > mayEnd ? currentYear + 1 : currentYear;
    };

    const challengeYear = getChallengeYear();
    const challengeStart = new Date(challengeYear, 4, 1, 0, 0, 0, 0);
    const challengeEnd = new Date(challengeYear, 4, 31, 23, 59, 59, 999);

    const getSundaysInMay = (year) => {
      const sundays = [];
      for (let day = 1; day <= 31; day += 1) {
        const date = new Date(year, 4, day);
        if (date.getDay() === 0) sundays.push(date);
      }
      return sundays.slice(1, 5);
    };

    const sundays = getSundaysInMay(challengeYear);

    const initProgressPoints = () => {
      const totalDuration = challengeEnd.getTime() - challengeStart.getTime();

      progressPointsElement.innerHTML = "";
      sundays.forEach((sunday, index) => {
        const elapsed = sunday.getTime() - challengeStart.getTime();
        const weekendPositionPercent = (elapsed / totalDuration) * 100;
        const slotPositionPercent = ((index + 0.5) / sundays.length) * 100;

        const winnerSlotLeft = document.createElement("span");
        winnerSlotLeft.className =
          "absolute top-1/2 h-10 w-10 md:h-14 md:w-14 rounded-full border-2 border-dashed border-primary/70 bg-gray-50 shadow-md dark:bg-gray-800";
        winnerSlotLeft.style.left = `${slotPositionPercent}%`;
        winnerSlotLeft.style.transform = "translate(-90%, -180%)";
        winnerSlotLeft.style.zIndex = "2";
        winnerSlotLeft.title = "Winner headshot";
        winnerSlotLeft.innerHTML = `<img src="${questionMarkImage}" alt="Winner placeholder" class="h-full w-full rounded-full object-cover" />`;

        const winnerSlotRight = document.createElement("span");
        winnerSlotRight.className =
          "absolute top-1/2 h-10 w-10 md:h-14 md:w-14 rounded-full border-2 border-dashed border-primary/70 bg-gray-50 shadow-md dark:bg-gray-800";
        winnerSlotRight.style.left = `${slotPositionPercent}%`;
        winnerSlotRight.style.transform = "translate(-10%, -180%)";
        winnerSlotRight.style.zIndex = "1";
        winnerSlotRight.title = "Winner headshot";
        winnerSlotRight.innerHTML = `<img src="${questionMarkImage}" alt="Winner placeholder" class="h-full w-full rounded-full object-cover" />`;

        const point = document.createElement("span");
        point.className =
          "absolute top-1/2 h-4 w-4 -translate-y-1/2 -translate-x-1/2 rounded-full border-2 border-primary bg-white dark:bg-gray-900";
        point.style.left = `${weekendPositionPercent}%`;
        point.title = sunday.toLocaleDateString(undefined, {
          month: "short",
          day: "numeric",
        });

        const label = document.createElement("span");
        label.className =
          "absolute top-6 -translate-x-1/2 text-[11px] font-medium text-gray-600 dark:text-gray-300";
        label.style.left = `${weekendPositionPercent}%`;
        label.textContent = sunday.toLocaleDateString(undefined, {
          month: "short",
          day: "numeric",
        });

        progressPointsElement.appendChild(winnerSlotRight);
        progressPointsElement.appendChild(winnerSlotLeft);
        progressPointsElement.appendChild(point);
        progressPointsElement.appendChild(label);
      });
    };

    const updateProgress = () => {
      const now = getNow();
      const totalDuration = challengeEnd.getTime() - challengeStart.getTime();
      const elapsed = now.getTime() - challengeStart.getTime();
      const clampedElapsed = Math.min(Math.max(elapsed, 0), totalDuration);
      const progress = (clampedElapsed / totalDuration) * 100;

      progressFillElement.style.width = `${progress}%`;

      const nextSunday = sundays.find((sunday) => now <= sunday);
      const msInDay = 1000 * 60 * 60 * 24;
      const rawDaysUntilNextSunday = nextSunday
        ? (nextSunday.getTime() - now.getTime()) / msInDay
        : 0;
      const daysUntilNextSunday = Math.max(0, Math.ceil(rawDaysUntilNextSunday));
      const isSundayMilestone = sundays.some(
        (sunday) =>
          sunday.getDate() === now.getDate() &&
          sunday.getMonth() === now.getMonth() &&
          sunday.getFullYear() === now.getFullYear(),
      );

      if (isSundayMilestone) {
        progressLabelTextElement.textContent = "";
        progressLabelHighlightElement.textContent = "New Winners Announced!";
      } else {
        const isBeforeFirstWinnerWeekend = sundays.length > 0 && now < sundays[0];
        progressLabelTextElement.textContent = isBeforeFirstWinnerWeekend
          ? "First Two Winners in "
          : "Next Two Winners in ";
        progressLabelHighlightElement.textContent = `${daysUntilNextSunday} Days`;
      }
    };

    initProgressPoints();
    updateProgress();
    setInterval(() => {
      updateProgress();
    }, 1000);
  }
</script>
