---
import unconnected_tripod from "../../assets/unconnected-tripod.png";
import instagram from "../../assets/instagram.png";
import stickCellyVideoLight from "../../assets/sikra-stick-celly-light.mp4";
import stickCellyVideoDark from "../../assets/sikra-stick-celly-dark.mp4";
import clippingVideoLight from "../../assets/sikra-clipping-light.mp4";
import clippingVideoDark from "../../assets/sikra-clipping-dark.mp4";
import prizes from "../../assets/prizes.png";
import question_mark from "../../assets/question_mark.jpg";

---

<div id="features">
  <!-- <Container> -->
  <div class="mx-10 mt-10 lg:my-10 lg:ml-32 lg:mr-10">
    <div
      class="space-y-6 justify-between text-gray-600 md:flex md:gap-6 md:space-y-0 lg:gap-4 "
    >
      <div class="md:w-1/2">
          <p
            class="mt-0 mb-0 text-center text-gray-900 dark:text-white font-bold text-4xl md:text-5xl xl:text-5xl"
          >Best Celly Wins a
            <span
              class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 font-bold text-4xl md:text-5xl xl:text-5xl"
            >
              $250 Prize Pack
            </span>
          </p>
          
          <img
            src={prizes}
            alt="dashboard screenshot"
            width="1500"
            height="1500"
            class="mx-auto mt-0 w-full max-w-2xl md:mt-0"
          />
          <p class="mt-8 mb-8 text-center text-lg text-gray-600 dark:text-gray-300">
          Exclusive Coach Bowman Training Tank, Tripod, One Year Coach Bowman Subscription, and a $100 Amazon Giftcard.
        </p>
        </div>
      <div class="md:w-1/2">
          <p
            class="mt-0 mb-0 text-center text-gray-900 dark:text-white font-bold text-4xl md:text-5xl xl:text-5xl"
          >
            <span
              class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 font-bold text-4xl md:text-5xl xl:text-5xl"
            >
              Stick
            </span> 
            a Dismount, Hit a 
            <span
              class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 font-bold text-4xl md:text-5xl xl:text-5xl"
            >
              Celly. 
            </span> 
            
            
          </p>
         
          <video
          class="mx-auto w-full max-w-2xl dark:hidden"
          src={stickCellyVideoLight}
          width="2000"
          height="2880"
          autoplay
          loop
          muted
          playsinline
        ></video>
        <video
          class="mx-auto hidden w-full max-w-2xl dark:block"
          src={stickCellyVideoDark}
          width="2000"
          height="2880"
          autoplay
          loop
          muted
          playsinline
        ></video>
        <p class="mt-8 mb-8 text-center text-lg text-gray-600 dark:text-gray-300">
            Capture a stuck dismount followed by your favorite celebration using the Coach Bowman app. Want to stand out? Add your favorite skills before the dismount. 
        </p>
        </div>
        </div>
    <div
      class="space-y-6 justify-between text-gray-600 md:flex flex-row-reverse md:gap-6 md:space-y-0 lg:gap-4 lg:items-center"
    >
      
      
    </div>
  </div>
  <div class="my-10 lg:my-10 lg:ml-32 lg:mr-10">
    <section
      class="mx-auto max-w-6xl"
      id="how-to-enter"
    >
      <div class="mx-auto max-w-4xl text-center">
        <h2
          class="text-4xl font-bold text-gray-900 md:text-4xl xl:text-5xl dark:text-white"
        >
          How to Enter the
          <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 font-bold"
            >#StickCellyContest</span
          >
        </h2>
      </div>

      <div class="mt-2" data-contest-carousel tabindex="0" style="touch-action: pan-y;">
        <div class="overflow-hidden" data-contest-viewport>
          <div
            class="flex items-start gap-1 py-2 transition-transform duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] will-change-transform motion-reduce:transition-none"
            data-contest-track
          >
          <article
            class="ml-4 grid w-[calc(100%-2.5rem)] shrink-0 content-start items-start gap-8 rounded-[1.75rem] border border-gray-100 bg-white p-6 shadow-2xl shadow-sky-500/10 transition-[opacity,transform] duration-300 dark:border-gray-700 dark:bg-gray-800 dark:shadow-sky-950/30 md:w-[calc(100%-4rem)] md:p-8 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)] lg:p-10"
            data-contest-slide
          >
            <div class="space-y-4 lg:self-start">
              <div class="flex items-center gap-3">
                <div class="inline-flex shrink-0 items-center gap-3 whitespace-nowrap rounded-full border border-sky-200 bg-sky-50 px-4 py-2 text-sm font-semibold text-sky-700 dark:border-sky-500/30 dark:bg-sky-500/10 dark:text-sky-300">
                  <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-sky-200 text-sky-800 dark:bg-sky-400/20 dark:text-sky-200">1</span>
                  Step 1 of 4
                </div>
                <p class="text-sm font-semibold uppercase tracking-[0.24em] text-sky-600 dark:text-sky-300">
                  Start in the app
                </p>
              </div>
              <div class="space-y-2">
                <h3 class="mt-3 text-2xl font-bold text-gray-900 dark:text-white md:text-3xl">
                  Download the Free Coach Bowman App
                </h3>
                <p class="text-base leading-8 text-gray-600 dark:text-gray-300 md:text-lg">
                  All submissions must be captured using the Coach Bowman app, and no payment is required to qualify for the contest.
                </p>
              </div>
              <!--
              <div class="grid gap-3 text-sm text-gray-600 dark:text-gray-300 md:text-base">
                <div class="flex items-start gap-3 rounded-2xl bg-white/80 px-4 py-3 shadow-sm dark:bg-gray-900/70">
                  <span class="mt-2 h-2.5 w-2.5 shrink-0 rounded-full bg-sky-500"></span>
                  Record your entry inside Coach Bowman so it counts as an official submission.
                </div>
                <div class="flex items-start gap-3 rounded-2xl bg-white/80 px-4 py-3 shadow-sm dark:bg-gray-900/70">
                  <span class="mt-2 h-2.5 w-2.5 shrink-0 rounded-full bg-sky-500"></span>
                  Get your setup ready before you move on to filming your stick and celly.
                </div>
              </div>
              -->
            </div>
            <div class="self-start overflow-hidden rounded-[1.5rem] border border-sky-200/60 bg-gradient-to-br from-sky-100 via-white to-indigo-100 dark:border-sky-500/20 dark:from-sky-500/10 dark:via-gray-900 dark:to-indigo-500/10">
              <img
                src={unconnected_tripod}
                alt="Coach Bowman app shown on a tripod setup"
                class="h-full w-full object-cover"
                width="6912"
                height="3456"
              />
            </div>
          </article>

          <article
            class="grid w-[calc(100%-2.5rem)] shrink-0 content-start items-start gap-8 rounded-[1.75rem] border border-gray-100 bg-white p-6 shadow-2xl shadow-blue-500/10 transition-[opacity,transform] duration-300 dark:border-gray-700 dark:bg-gray-800 dark:shadow-blue-950/30 md:w-[calc(100%-4rem)] md:p-8 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)] lg:p-10"
            data-contest-slide
          >
            <div class="space-y-4 lg:self-start">
              <div class="flex items-center gap-3">
                <div class="inline-flex shrink-0 items-center gap-3 whitespace-nowrap rounded-full border border-blue-200 bg-blue-50 px-4 py-2 text-sm font-semibold text-blue-700 dark:border-blue-500/30 dark:bg-blue-500/10 dark:text-blue-300">
                  <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-blue-200 text-blue-800 dark:bg-blue-400/20 dark:text-blue-200">2</span>
                  Step 2 of 4
                </div>
                <p class="text-sm font-semibold uppercase tracking-[0.24em] text-blue-600 dark:text-blue-300">
                  Film your clip
                </p>
              </div>
              <div class="space-y-2">
                <h3 class="mt-3 text-2xl font-bold text-gray-900 dark:text-white md:text-3xl">
                  Capture Your Stick &amp; Celly in the App
                </h3>
                <p class="text-base leading-8 text-gray-600 dark:text-gray-300 md:text-lg">
                  Use Coach Bowman to record a stuck dismount followed immediately by your favorite celebration. Best celly wins.
                </p>
              </div>
              <!--
              <div class="grid gap-3 text-sm text-gray-600 dark:text-gray-300 md:text-base">
                <div class="flex items-start gap-3 rounded-2xl bg-white/80 px-4 py-3 shadow-sm dark:bg-gray-900/70">
                  <span class="mt-2 h-2.5 w-2.5 shrink-0 rounded-full bg-blue-500"></span>
                  Make the stuck landing clear first, then let the celebration be the moment that stands out.
                </div>
                <div class="flex items-start gap-3 rounded-2xl bg-white/80 px-4 py-3 shadow-sm dark:bg-gray-900/70">
                  <span class="mt-2 h-2.5 w-2.5 shrink-0 rounded-full bg-blue-500"></span>
                  If you want extra style points, add your favorite skills before the dismount.
                </div>
              </div>
              -->
            </div>
            <div class="self-start overflow-hidden rounded-[1.5rem] border border-blue-200/60 bg-gradient-to-br from-blue-100 via-white to-cyan-100 dark:border-blue-500/20 dark:from-blue-500/10 dark:via-gray-900 dark:to-cyan-500/10">
              <div class="relative aspect-[4/3] w-full overflow-hidden">
                <video
                  class="absolute left-1/2 top-1/2 block h-auto w-[75%] max-w-none -translate-x-1/2 -translate-y-1/2 rotate-90 origin-center dark:hidden"
                  src={stickCellyVideoLight}
                  width="2000"
                  height="2880"
                  autoplay
                  loop
                  muted
                  playsinline
                ></video>
                <video
                  class="absolute left-1/2 top-1/2 hidden h-auto w-[75%] max-w-none -translate-x-1/2 -translate-y-1/2 rotate-90 origin-center dark:block"
                  src={stickCellyVideoDark}
                  width="2000"
                  height="2880"
                  autoplay
                  loop
                  muted
                  playsinline
                ></video>
              </div>
            </div>
          </article>

          <article
            class="grid w-[calc(100%-2.5rem)] shrink-0 content-start items-start gap-8 rounded-[1.75rem] border border-gray-100 bg-white p-6 shadow-2xl shadow-purple-500/10 transition-[opacity,transform] duration-300 dark:border-gray-700 dark:bg-gray-800 dark:shadow-purple-950/30 md:w-[calc(100%-4rem)] md:p-8 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)] lg:p-10"
            data-contest-slide
          >
            <div class="space-y-4 lg:self-start">
              <div class="flex items-center gap-3">
                <div class="inline-flex shrink-0 items-center gap-3 whitespace-nowrap rounded-full border border-purple-200 bg-purple-50 px-4 py-2 text-sm font-semibold text-purple-700 dark:border-purple-500/30 dark:bg-purple-500/10 dark:text-purple-300">
                  <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-purple-200 text-purple-800 dark:bg-purple-400/20 dark:text-purple-200">3</span>
                  Step 3 of 4
                </div>
                <p class="text-sm font-semibold uppercase tracking-[0.24em] text-purple-600 dark:text-purple-300">
                  Make it official
                </p>
              </div>
              <div class="space-y-2">
                <h3 class="mt-3 text-2xl font-bold text-gray-900 dark:text-white md:text-3xl">
                  Include the Required Watermark
                </h3>
                <p class="text-base leading-8 text-gray-600 dark:text-gray-300 md:text-lg">
                  Use the <span class="font-semibold text-gray-900 dark:text-white">#StickCellyContest</span> button while clipping to add the required watermark and agree to the contest terms and conditions.
                </p>
              </div>
              <!--
              <div class="grid gap-3 text-sm text-gray-600 dark:text-gray-300 md:text-base">
                <div class="flex items-start gap-3 rounded-2xl bg-white/80 px-4 py-3 shadow-sm dark:bg-gray-900/70">
                  <span class="mt-2 h-2.5 w-2.5 shrink-0 rounded-full bg-purple-500"></span>
                  This step is what visually confirms your clip is part of the contest.
                </div>
                <div class="flex items-start gap-3 rounded-2xl bg-white/80 px-4 py-3 shadow-sm dark:bg-gray-900/70">
                  <span class="mt-2 h-2.5 w-2.5 shrink-0 rounded-full bg-purple-500"></span>
                  Apply the contest clip treatment before exporting so your final post is ready to go.
                </div>
              </div>
              -->
            </div>
            <div class="self-start overflow-hidden rounded-[1.5rem] border border-purple-200/60 bg-gradient-to-br from-purple-100 via-white to-fuchsia-100 dark:border-purple-500/20 dark:from-purple-500/10 dark:via-gray-900 dark:to-fuchsia-500/10">
              <div class="relative aspect-[4/3] w-full overflow-hidden">
                <video
                  class="absolute left-1/2 top-1/2 block h-auto w-[75%] max-w-none -translate-x-1/2 -translate-y-1/2 rotate-90 origin-center dark:hidden"
                  src={clippingVideoLight}
                  width="2000"
                  height="2880"
                  autoplay
                  loop
                  muted
                  playsinline
                ></video>
                <video
                  class="absolute left-1/2 top-1/2 hidden h-auto w-[75%] max-w-none -translate-x-1/2 -translate-y-1/2 rotate-90 origin-center dark:block"
                  src={clippingVideoDark}
                  width="2000"
                  height="2880"
                  autoplay
                  loop
                  muted
                  playsinline
                ></video>
              </div>
            </div>
          </article>

          <article
            class="mr-4 grid w-[calc(100%-2.5rem)] shrink-0 content-start items-start gap-8 rounded-[1.75rem] border border-gray-100 bg-white p-6 shadow-2xl shadow-green-500/10 transition-[opacity,transform] duration-300 dark:border-gray-700 dark:bg-gray-800 dark:shadow-green-950/30 md:w-[calc(100%-4rem)] md:p-8 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)] lg:p-10"
            data-contest-slide
          >
            <div class="space-y-4 lg:self-start">
              <div class="flex items-center gap-3">
                <div class="inline-flex shrink-0 items-center gap-3 whitespace-nowrap rounded-full border border-green-200 bg-green-50 px-4 py-2 text-sm font-semibold text-green-700 dark:border-green-500/30 dark:bg-green-500/10 dark:text-green-300">
                  <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-green-200 text-green-800 dark:bg-green-400/20 dark:text-green-200">4</span>
                  Step 4 of 4
                </div>
                <p class="text-sm font-semibold uppercase tracking-[0.24em] text-green-600 dark:text-green-300">
                  Submit your entry
                </p>
              </div>
              <div class="space-y-2">
                <h3 class="mt-3 text-2xl font-bold text-gray-900 dark:text-white md:text-3xl">
                  Post on Instagram, Tag @coach.bowman.app, and Hashtag #StickCellyContest
                </h3>
                <p class="text-base leading-8 text-gray-600 dark:text-gray-300 md:text-lg">
                  Share your clip as a Reel, tag us, and include the hashtag to complete your entry.
                </p>
              </div>
              <!--
              <div class="grid gap-3 text-sm text-gray-600 dark:text-gray-300 md:text-base">
                <div class="flex items-start gap-3 rounded-2xl bg-white/80 px-4 py-3 shadow-sm dark:bg-gray-900/70">
                  <span class="mt-2 h-2.5 w-2.5 shrink-0 rounded-full bg-green-500"></span>
                  Posting as a Reel gives the contest team a public, shareable version of your submission.
                </div>
                <div class="flex items-start gap-3 rounded-2xl bg-white/80 px-4 py-3 shadow-sm dark:bg-gray-900/70">
                  <span class="mt-2 h-2.5 w-2.5 shrink-0 rounded-full bg-green-500"></span>
                  Double-check the tag and hashtag before you publish so your entry is easy to find.
                </div>
              </div>
              -->
            </div>
            <div class="self-start overflow-hidden rounded-[1.5rem] border border-green-200/60 bg-gradient-to-br from-green-100 via-white to-emerald-100 dark:border-green-500/20 dark:from-green-500/10 dark:via-gray-900 dark:to-emerald-500/10">
              <img
                src={instagram}
                alt="Instagram reel screen used to complete the contest entry"
                class="h-full w-full object-cover"
                width="2150"
                height="1640"
              />
            </div>
          </article>
          </div>
        </div>

        <div class="mt-6 flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
          <div class="flex items-center justify-center gap-2">
            <button
              type="button"
              class="h-3 w-3 rounded-full bg-primary transition-transform duration-200"
              data-contest-indicator
              aria-label="Go to step 1"
              aria-pressed="true"
            ></button>
            <button
              type="button"
              class="h-3 w-3 rounded-full bg-gray-300 transition-transform duration-200 dark:bg-gray-700"
              data-contest-indicator
              aria-label="Go to step 2"
              aria-pressed="false"
            ></button>
            <button
              type="button"
              class="h-3 w-3 rounded-full bg-gray-300 transition-transform duration-200 dark:bg-gray-700"
              data-contest-indicator
              aria-label="Go to step 3"
              aria-pressed="false"
            ></button>
            <button
              type="button"
              class="h-3 w-3 rounded-full bg-gray-300 transition-transform duration-200 dark:bg-gray-700"
              data-contest-indicator
              aria-label="Go to step 4"
              aria-pressed="false"
            ></button>
          </div>

          <div class="flex flex-col items-center gap-3 sm:flex-row">
            <span
              class="text-sm font-medium text-gray-500 dark:text-gray-400"
              data-contest-status
            >
              Step 1 of 4
            </span>
            <div class="flex items-center gap-3">
              <button
                type="button"
                class="inline-flex min-h-[2.75rem] items-center justify-center rounded-full border border-gray-200 bg-white px-5 text-sm font-semibold text-gray-700 transition duration-200 hover:border-primary hover:text-primary disabled:cursor-not-allowed disabled:opacity-45 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-200"
                data-contest-prev
              >
                Previous
              </button>
              <button
                type="button"
                class="inline-flex min-h-[2.75rem] items-center justify-center rounded-full bg-[linear-gradient(82deg,#9936FD_0%,#484FF3_100%)] px-5 text-sm font-semibold text-white transition duration-200 hover:scale-[1.01] disabled:cursor-not-allowed disabled:opacity-45"
                data-contest-next
              >
                Next
              </button>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
  <div class="m-10 lg:my-10 lg:ml-32 lg:mr-10">
    <div
      class="space-y-6 justify-between text-gray-600 md:flex flex-row-reverse md:gap-6 md:space-y-0 lg:gap-4 lg:items-center"
    >
     
      <div class="max-w-3xl mx-auto">
        <h2
          class="text-3xl font-bold text-gray-900 md:text-4xl dark:text-white"
        > Additional Information 
         
        </h2>
        <div class="divide-y space-y-4 divide-gray-100 dark:divide-gray-800">
          <div class="pt-8 flex gap-4 md:items-center">
            <div
              class="w-12 h-12 flex gap-4 rounded-full bg-blue-200 dark:bg-blue-900/20"
            >
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 m-auto text-blue-700 dark:text-blue-400">
                <rect x="3" y="6" width="10" height="12" rx="2"></rect>
                <rect x="7" y="3" width="10" height="12" rx="2"></rect>
                <path d="M19 15v6"></path>
                <path d="M16 18h6"></path>
              </svg>
            </div>
            <div class="w-5/6">
              <h4
                class="font-semibold text-lg text-gray-700 dark:text-blue-400"
              >
                Multiple Submissions
              </h4>
              <p class="text-gray-500 dark:text-gray-400">
                Participants may submit an unlimited number of unique entries up to the last drawing in June. 
              </p>
            </div>
          </div>

          <div class="pt-4 flex gap-4 md:items-center">
            
            <div
              class="w-12 h-12 flex gap-4 rounded-full bg-green-100 dark:bg-green-900/20"
            >
              <div
                class="w-12 h-12 flex gap-4 rounded-full bg-green-100 dark:bg-green-900/20"
              >
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 m-auto text-green-600 dark:text-green-400">
                  <rect x="7" y="4" width="10" height="16" rx="2"></rect>
                  <path d="M9 4h6v3H9z"></path>
                  <path d="M8.5 13.5l2 2 4-4"></path>
                </svg>
              </div>
            </div>
            <div class="w-5/6">
              <h4
                class="font-semibold text-lg text-gray-700 dark:text-green-400"
              >
                How Winners Are Picked
              </h4>
              <p class="text-gray-500 dark:text-gray-400">
                Best celly wins! We pick the most creative, funny, or unique entries. It is
                not about the hardest skill or highest score. 
              </p>
            </div>
          </div>
          <div class="pt-4 flex gap-4 md:items-center">
            <div
              class="w-12 h-12 flex gap-4 rounded-full bg-purple-200 dark:bg-purple-900/20"
            >
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 m-auto text-purple-600 dark:text-purple-400">
                <rect x="7" y="2" width="10" height="20" rx="2"></rect>
                <rect x="10" y="18" width="4" height="1" rx="0.5"></rect>
              </svg>
            </div>
            <div class="w-5/6">
              <h4
                class="font-semibold text-lg text-gray-700 dark:text-purple-400"
              >
                How We Will Contact Winners
              </h4>
              <p class="text-gray-500 dark:text-gray-400">
                Winners will be messaged on Instagram. Be sure to follow @coach.bowman.app and have your DMs open. Winners are expected to respond within 48 hours to claim their prizes, and provide a photo for the winner announcement posts. If a winner does not respond within 48 hours, an alternate winner will be selected.
              </p>
            </div>
          </div>
         
        </div>
      </div>
    </div>
  </div>
  <div class="mx-10">
    <div class="mx-auto py-8 border-y border-gray-100 dark:border-gray-800 mt-6 w-full max-w-5xl">
      <p
        id="giveaway-progress-label"
        class="mb-24 text-center text-gray-900 dark:text-white font-bold text-4xl md:text-5xl xl:text-6xl md:mb-32"
      >
        <span id="giveaway-progress-text">Two New Winners in </span>
        <span
          id="giveaway-progress-highlight"
          class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 font-bold text-4xl md:text-5xl xl:text-6xl"
        >
          0 Days
        </span>
      </p>
      <div class="relative h-3 overflow-visible rounded-full bg-gray-200 dark:bg-gray-700">
        <div
          id="giveaway-progress-fill"
          class="h-full rounded-full bg-primary transition-all duration-500"
          style="width: 0%;"
        >
        </div>
        <div
          id="giveaway-progress-points"
          class="absolute inset-0"
          data-question-mark={question_mark}
        ></div>
      </div>
       <div
        class="mt-2 flex items-center justify-between text-sm text-gray-600 dark:text-gray-300"
      >
      </div>
    </div>
  </div>
</div>


<script>
  const progressFillElement = document.getElementById("giveaway-progress-fill");
  const progressPointsElement = document.getElementById("giveaway-progress-points");
  const progressLabelElement = document.getElementById("giveaway-progress-label");
  const progressLabelTextElement = document.getElementById("giveaway-progress-text");
  const progressLabelHighlightElement = document.getElementById("giveaway-progress-highlight");
  const CHALLENGE_MONTH_INDEX = 5; // June. JavaScript months are zero-based.
  const MANUAL_TEST_DATE = "";
  // const MANUAL_TEST_DATE = "2026-06-30T12:00:00";
  const getNow = () => (MANUAL_TEST_DATE ? new Date(MANUAL_TEST_DATE) : new Date());
  const questionMarkImage = progressPointsElement?.dataset.questionMark || "";

  if (
    progressFillElement &&
    progressPointsElement &&
    progressLabelElement &&
    progressLabelTextElement &&
    progressLabelHighlightElement
  ) {
    const getChallengeEnd = (year) =>
      new Date(year, CHALLENGE_MONTH_INDEX + 1, 0, 23, 59, 59, 999);

    const getChallengeYear = () => {
      const now = getNow();
      const currentYear = now.getFullYear();
      const challengeEndThisYear = getChallengeEnd(currentYear);
      return now > challengeEndThisYear ? currentYear + 1 : currentYear;
    };

    const challengeYear = getChallengeYear();
    const challengeStart = new Date(challengeYear, CHALLENGE_MONTH_INDEX, 1, 0, 0, 0, 0);
    const challengeEnd = getChallengeEnd(challengeYear);

    const getSundaysInChallengeMonth = (year) => {
      const sundays = [];
      const lastDayOfMonth = getChallengeEnd(year).getDate();
      for (let day = 1; day <= lastDayOfMonth; day += 1) {
        const date = new Date(year, CHALLENGE_MONTH_INDEX, day);
        if (date.getDay() === 0) sundays.push(date);
      }
      return sundays;
    };

    const sundays = getSundaysInChallengeMonth(challengeYear);

    const initProgressPoints = () => {
      const totalDuration = challengeEnd.getTime() - challengeStart.getTime();

      progressPointsElement.innerHTML = "";
      sundays.forEach((sunday, index) => {
        const elapsed = sunday.getTime() - challengeStart.getTime();
        const weekendPositionPercent = (elapsed / totalDuration) * 100;
        const slotPositionPercent = ((index + 0.5) / sundays.length) * 100;

        const winnerSlotLeft = document.createElement("span");
        winnerSlotLeft.className =
          "absolute top-1/2 h-10 w-10 md:h-14 md:w-14 rounded-full border-2 border-dashed border-primary/70 bg-gray-50 shadow-md dark:bg-gray-800";
        winnerSlotLeft.style.left = `${slotPositionPercent}%`;
        winnerSlotLeft.style.transform = "translate(-90%, -180%)";
        winnerSlotLeft.style.zIndex = "2";
        winnerSlotLeft.title = "Winner headshot";
        winnerSlotLeft.innerHTML = `<img src="${questionMarkImage}" alt="Winner placeholder" class="h-full w-full rounded-full object-cover" />`;

        const winnerSlotRight = document.createElement("span");
        winnerSlotRight.className =
          "absolute top-1/2 h-10 w-10 md:h-14 md:w-14 rounded-full border-2 border-dashed border-primary/70 bg-gray-50 shadow-md dark:bg-gray-800";
        winnerSlotRight.style.left = `${slotPositionPercent}%`;
        winnerSlotRight.style.transform = "translate(-10%, -180%)";
        winnerSlotRight.style.zIndex = "1";
        winnerSlotRight.title = "Winner headshot";
        winnerSlotRight.innerHTML = `<img src="${questionMarkImage}" alt="Winner placeholder" class="h-full w-full rounded-full object-cover" />`;

        const point = document.createElement("span");
        point.className =
          "absolute top-1/2 h-4 w-4 -translate-y-1/2 -translate-x-1/2 rounded-full border-2 border-primary bg-white dark:bg-gray-900";
        point.style.left = `${weekendPositionPercent}%`;
        point.title = sunday.toLocaleDateString(undefined, {
          month: "short",
          day: "numeric",
        });

        const label = document.createElement("span");
        label.className =
          "absolute top-6 -translate-x-1/2 text-[11px] font-medium text-gray-600 dark:text-gray-300";
        label.style.left = `${weekendPositionPercent}%`;
        label.textContent = sunday.toLocaleDateString(undefined, {
          month: "short",
          day: "numeric",
        });

        progressPointsElement.appendChild(winnerSlotRight);
        progressPointsElement.appendChild(winnerSlotLeft);
        progressPointsElement.appendChild(point);
        progressPointsElement.appendChild(label);
      });
    };

    const updateProgress = () => {
      const now = getNow();
      const totalDuration = challengeEnd.getTime() - challengeStart.getTime();
      const elapsed = now.getTime() - challengeStart.getTime();
      const clampedElapsed = Math.min(Math.max(elapsed, 0), totalDuration);
      const progress = (clampedElapsed / totalDuration) * 100;

      progressFillElement.style.width = `${progress}%`;

      const nextSunday = sundays.find((sunday) => now <= sunday);
      const msInDay = 1000 * 60 * 60 * 24;
      const rawDaysUntilNextSunday = nextSunday
        ? (nextSunday.getTime() - now.getTime()) / msInDay
        : 0;
      const daysUntilNextSunday = Math.max(0, Math.ceil(rawDaysUntilNextSunday));
      const isSundayMilestone = sundays.some(
        (sunday) =>
          sunday.getDate() === now.getDate() &&
          sunday.getMonth() === now.getMonth() &&
          sunday.getFullYear() === now.getFullYear(),
      );

      if (isSundayMilestone) {
        progressLabelTextElement.textContent = "";
        progressLabelHighlightElement.textContent = "New Winners Announced!";
      } else {
        const isBeforeFirstWinnerWeekend = sundays.length > 0 && now < sundays[0];
        progressLabelTextElement.textContent = isBeforeFirstWinnerWeekend
          ? "First Two Winners in "
          : "Next Two Winners in ";
        progressLabelHighlightElement.textContent = `${daysUntilNextSunday} Days`;
      }
    };

    initProgressPoints();
    updateProgress();
    setInterval(() => {
      updateProgress();
    }, 1000);
  }

  const contestCarousels = document.querySelectorAll("[data-contest-carousel]");

  contestCarousels.forEach((carousel) => {
    const viewport = carousel.querySelector("[data-contest-viewport]");
    const track = carousel.querySelector("[data-contest-track]");
    const slides = Array.from(carousel.querySelectorAll("[data-contest-slide]"));
    const indicators = Array.from(
      carousel.querySelectorAll("[data-contest-indicator]"),
    );
    const status = carousel.querySelector("[data-contest-status]");
    const previousButton = carousel.querySelector("[data-contest-prev]");
    const nextButton = carousel.querySelector("[data-contest-next]");

    if (
      !viewport ||
      !track ||
      !slides.length ||
      !status ||
      !previousButton ||
      !nextButton ||
      indicators.length !== slides.length
    ) {
      return;
    }

    let activeIndex = 0;
    let touchStartX = 0;
    let touchStartY = 0;
    let touchHasMoved = false;
    let touchIsDragging = false;
    let dragStartTranslate = 0;
    let currentTranslate = 0;

    const getTranslateBounds = () => {
      const lastSlide = slides[slides.length - 1];

      if (!lastSlide) {
        return {
          maxTranslate: 0,
          minTranslate: 0,
        };
      }

      const centeredLastSlideTranslate =
        viewport.clientWidth / 2 -
        (lastSlide.offsetLeft + lastSlide.offsetWidth / 2);

      return {
        maxTranslate: 0,
        minTranslate: Math.min(0, centeredLastSlideTranslate),
      };
    };

    const clampTranslate = (translate, overflow = 0) => {
      const { minTranslate, maxTranslate } = getTranslateBounds();
      return Math.min(
        maxTranslate + overflow,
        Math.max(minTranslate - overflow, translate),
      );
    };

    const updateNavigationState = () => {
      previousButton.disabled = activeIndex === 0;
      nextButton.disabled = activeIndex === slides.length - 1;
    };

    const renderActiveSlide = ({
      animate = true,
      translateOverride,
      allowOverflow = 0,
    } = {}) => {
      track.style.transitionDuration = animate ? "" : "0ms";

      const activeSlide = slides[activeIndex];
      if (!activeSlide) return;

      const targetTranslate =
        viewport.clientWidth / 2 -
        (activeSlide.offsetLeft + activeSlide.offsetWidth / 2);

      currentTranslate =
        typeof translateOverride === "number"
          ? clampTranslate(translateOverride, allowOverflow)
          : clampTranslate(targetTranslate);

      track.style.transform = `translateX(${currentTranslate}px)`;

      slides.forEach((slide, index) => {
        const isActive = index === activeIndex;
        slide.setAttribute("aria-hidden", String(!isActive));
      });

      indicators.forEach((indicator, index) => {
        const isActive = index === activeIndex;
        indicator.setAttribute("aria-pressed", String(isActive));
        indicator.classList.toggle("bg-primary", isActive);
        indicator.classList.toggle("scale-125", isActive);
        indicator.classList.toggle("bg-gray-300", !isActive);
        indicator.classList.toggle("dark:bg-gray-700", !isActive);
      });

      status.textContent = `Step ${activeIndex + 1} of ${slides.length}`;
      updateNavigationState();
    };

    const moveToSlide = (index) => {
      const clampedIndex = Math.max(0, Math.min(slides.length - 1, index));
      activeIndex = clampedIndex;
      renderActiveSlide({ animate: true });
    };

    previousButton.addEventListener("click", () => {
      if (activeIndex > 0) moveToSlide(activeIndex - 1);
    });

    nextButton.addEventListener("click", () => {
      if (activeIndex < slides.length - 1) moveToSlide(activeIndex + 1);
    });

    indicators.forEach((indicator, index) => {
      indicator.addEventListener("click", () => {
        moveToSlide(index);
      });
    });

    carousel.addEventListener("keydown", (event) => {
      if (event.key === "ArrowLeft") {
        event.preventDefault();
        moveToSlide(activeIndex - 1);
      }

      if (event.key === "ArrowRight") {
        event.preventDefault();
        moveToSlide(activeIndex + 1);
      }
    });

    carousel.addEventListener(
      "touchstart",
      (event) => {
        const touch = event.changedTouches[0];
        if (!touch) return;

        touchStartX = touch.clientX;
        touchStartY = touch.clientY;
        touchHasMoved = true;
        touchIsDragging = false;
        dragStartTranslate = currentTranslate;
        track.style.transitionDuration = "0ms";
      },
      { passive: true },
    );

    carousel.addEventListener(
      "touchmove",
      (event) => {
        if (!touchHasMoved) return;

        const touch = event.changedTouches[0];
        if (!touch) return;

        const deltaX = touch.clientX - touchStartX;
        const deltaY = touch.clientY - touchStartY;

        if (!touchIsDragging) {
          if (Math.abs(deltaX) < 10 || Math.abs(deltaX) <= Math.abs(deltaY)) {
            return;
          }

          touchIsDragging = true;
        }

        renderActiveSlide({
          animate: false,
          translateOverride: dragStartTranslate + deltaX,
          allowOverflow: 40,
        });
      },
      { passive: true },
    );

    carousel.addEventListener(
      "touchend",
      (event) => {
        if (!touchHasMoved) return;

        const touch = event.changedTouches[0];
        if (!touch) return;

        const deltaX = touch.clientX - touchStartX;
        const deltaY = touch.clientY - touchStartY;
        const swipeThreshold = 50;
        const isHorizontalSwipe = Math.abs(deltaX) > Math.abs(deltaY);

        if (
          touchIsDragging &&
          isHorizontalSwipe &&
          Math.abs(deltaX) > swipeThreshold
        ) {
          if (deltaX < 0) {
            moveToSlide(activeIndex + 1);
          } else {
            moveToSlide(activeIndex - 1);
          }
        } else {
          renderActiveSlide({ animate: true });
        }

        touchHasMoved = false;
        touchIsDragging = false;
      },
      { passive: true },
    );

    carousel.addEventListener("touchcancel", () => {
      touchHasMoved = false;
      touchIsDragging = false;
      renderActiveSlide({ animate: true });
    });

    const syncCarouselLayout = () => {
      renderActiveSlide({ animate: false });
    };

    window.addEventListener("resize", syncCarouselLayout);

    if (typeof ResizeObserver !== "undefined") {
      const resizeObserver = new ResizeObserver(syncCarouselLayout);
      resizeObserver.observe(viewport);
    }

    renderActiveSlide({ animate: false });
  });
</script>
