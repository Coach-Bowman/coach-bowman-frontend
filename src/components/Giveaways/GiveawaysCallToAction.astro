---
import Container from "../Container.astro";
---

<div class="relative py-16" id="official-entry-form">
  <Container>
    <div class="relative">
      <div class="mt-6 m-auto space-y-6 md:w-8/12 lg:w-7/12">
         <h2
          class="text-3xl font-bold text-gray-900 md:text-4xl dark:text-white text-center"
        >Enter the
          <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 font-bold"
            >#CoachBowmanContest</span
          >
        </h2>

        <p class="text-center text-xl text-gray-600 dark:text-gray-300">
          To officially enter #CoachBowmanContest, you must complete this
          form and agree to the Terms and Conditions.
        </p>
        <form
          id="official-entry-form-card"
          class="mx-auto mt-10 w-full max-w-2xl rounded-2xl border border-gray-200 bg-white/90 p-6 text-left shadow-md backdrop-blur dark:border-gray-700 dark:bg-gray-900/70"
        >
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white">
            Official Entry Form
          </h2>
          <p class="mt-2 text-sm text-gray-600 dark:text-gray-300">
            This legal form is required for giveaway eligibility. Entries
            without this form and Terms acceptance are not valid.
          </p>
          <div class="mt-6 grid grid-cols-1 gap-4 md:grid-cols-2">
            <label class="block">
              <span class="mb-2 block text-sm font-semibold text-gray-700 dark:text-gray-200">
                First Name
              </span>
              <input
                type="text"
                id="giveaway-first-name"
                name="firstName"
                placeholder="First Name"
                required
                class="w-full rounded-xl border border-gray-300 bg-white px-4 py-3 text-gray-900 outline-none transition focus:border-primary focus:ring-2 focus:ring-primary/20 dark:border-gray-600 dark:bg-gray-800 dark:text-white"
              />
            </label>
            <label class="block">
              <span class="mb-2 block text-sm font-semibold text-gray-700 dark:text-gray-200">
                Last Name
              </span>
              <input
                type="text"
                id="giveaway-last-name"
                name="lastName"
                placeholder="Last Name"
                required
                class="w-full rounded-xl border border-gray-300 bg-white px-4 py-3 text-gray-900 outline-none transition focus:border-primary focus:ring-2 focus:ring-primary/20 dark:border-gray-600 dark:bg-gray-800 dark:text-white"
              />
            </label>
          </div>
          <label class="mt-5 flex items-start gap-3">
            <input
              type="checkbox"
              name="termsAccepted"
              required
              class="mt-1 h-5 w-5 rounded border-gray-300 text-primary focus:ring-primary dark:border-gray-600 dark:bg-gray-800"
            />
            <span class="text-sm text-gray-700 dark:text-gray-200">
              I agree to the
              <a
                href="#terms-and-conditions"
                class="font-semibold text-primary underline underline-offset-4"
              >
                Terms and Conditions
              </a>.
            </span>
          </label>
          <label class="mt-4 flex items-start gap-3">
            <input
              type="checkbox"
              name="ageOrParentConsent"
              required
              class="mt-1 h-5 w-5 rounded border-gray-300 text-primary focus:ring-primary dark:border-gray-600 dark:bg-gray-800"
            />
            <span class="text-sm text-gray-700 dark:text-gray-200">
              I am 18 or older, or I have parent/guardian consent to enter this contest.
            </span>
          </label>
          <button
            id="official-entry-submit"
            type="submit"
            class="mt-6 inline-flex h-11 items-center justify-center rounded-full bg-primary px-6 text-sm font-semibold text-white transition hover:opacity-90"
          >
            Submit Official Entry Form
          </button>
        </form>
        <div
          id="official-entry-form-success"
          class="mx-auto mt-10 hidden w-full max-w-2xl rounded-2xl border border-green-200 bg-white/90 p-6 text-left shadow-md backdrop-blur dark:border-green-900/50 dark:bg-gray-900/70"
        >
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white">
            Official Entry Form Confirmed
          </h2>
          <p class="mt-2 text-sm text-gray-600 dark:text-gray-300">
            Your official entry form has been submitted. To complete your contest entry, finish the remaining steps below.
          </p>
          <div class="mt-6 space-y-4">
            <div class="rounded-xl border border-green-200 bg-green-50 px-4 py-3 dark:border-green-900/50 dark:bg-green-950/30">
              <p class="flex items-center gap-2 text-sm font-semibold text-green-700 dark:text-green-300">
                <span
                  class="flex h-5 w-5 items-center justify-center rounded-full bg-green-600 text-xs text-white"
                >
                  ✓
                </span>
                <span class="line-through">
                  Step 1: Submit the Official Entry Form
                </span>
              </p>
              <p class="mt-1 text-sm text-green-700/90 dark:text-green-300/90">
                Completed. Continue with the remaining steps below to finish your contest entry.
              </p>
            </div>
            <div class="rounded-xl border border-gray-200 bg-gray-50 px-4 py-3 dark:border-gray-700 dark:bg-gray-800/70">
              <p class="text-sm font-semibold text-gray-900 dark:text-white">
                Step 2: Download the Coach Bowman App
              </p>
              <p class="mt-1 text-sm text-gray-600 dark:text-gray-300">
                Your contest clip must be captured in the Coach Bowman app.
              </p>
            </div>
            <div class="rounded-xl border border-gray-200 bg-gray-50 px-4 py-3 dark:border-gray-700 dark:bg-gray-800/70">
              <p class="text-sm font-semibold text-gray-900 dark:text-white">
                Step 3: Capture Your Clip with the #CoachBowmanContest Watermark
              </p>
              <p class="mt-1 text-sm text-gray-600 dark:text-gray-300">
                Use the #CoachBowmanContest button while clipping so the required watermark and overlay are included.
              </p>
            </div>
            <div class="rounded-xl border border-gray-200 bg-gray-50 px-4 py-3 dark:border-gray-700 dark:bg-gray-800/70">
              <p class="text-sm font-semibold text-gray-900 dark:text-white">
                Step 4: Post on Instagram, Tag @coach.bowman.app, and Hashtag #CoachBowmanContest
              </p>
              <p class="mt-1 text-sm text-gray-600 dark:text-gray-300">
                Post your Reel, tag @coach.bowman.app, and include #CoachBowmanContest to complete your entry.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div
      aria-hidden="true"
      class="relative inset-0 h-max w-full m-auto grid grid-cols-2 -space-x-52 -z-10 opacity-30 dark:opacity-20"
    >
      <div
        class="absolute inset-0 blur-[106px] h-56 bg-gradient-to-br from-primary to-cyan-400"
      >
      </div>
      <div
        class="absolute inset-0 blur-[106px] h-32 bg-gradient-to-r from-primary to-cyan-400"
      >
      </div>
    </div>
  </Container>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const form = document.getElementById(
      "official-entry-form-card",
    ) as HTMLFormElement | null;
    const successCard = document.getElementById("official-entry-form-success");
    const submitButton = document.getElementById(
      "official-entry-submit",
    ) as HTMLButtonElement | null;

    if (!form || !successCard || !submitButton) {
      return;
    }

    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      submitButton.disabled = true;
      submitButton.textContent = "Submitting...";
      await new Promise((resolve) => setTimeout(resolve, 250));

      form.classList.add("hidden");
      successCard.classList.remove("hidden");
    });
  });
</script>
