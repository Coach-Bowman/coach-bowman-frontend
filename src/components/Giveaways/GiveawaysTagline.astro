                    <img src="./images/clients/netflix.svg" class="h-8 w-auto m-auto" loading="lazy" alt="client logo" width="" height="" />
                  </div>
                <div class="p-4 grayscale transition duration-200 hover:grayscale-0">
                    <img src="./images/clients/google-cloud.svg" class="h-12 w-auto mx-auto" loading="lazy" alt="client logo" width="" height="" />
                </div>
              </div> -->
    </div>
  </Container>
</div>

<script>
  const progressFillElement = document.getElementById("giveaway-progress-fill");
  const progressPointsElement = document.getElementById("giveaway-progress-points");
  const progressLabelElement = document.getElementById("giveaway-progress-label");
  const progressLabelTextElement = document.getElementById("giveaway-progress-text");
  const progressLabelHighlightElement = document.getElementById("giveaway-progress-highlight");
  const MANUAL_TEST_DATE = "2026-04-06T12:00:00";
  const getNow = () => (MANUAL_TEST_DATE ? new Date(MANUAL_TEST_DATE) : new Date());
  const questionMarkImage = progressPointsElement?.dataset.questionMark || "";

  if (
    progressFillElement &&
    progressPointsElement &&
    progressLabelElement &&
    progressLabelTextElement &&
    progressLabelHighlightElement
  ) {
    const getChallengeYear = () => {
      const now = getNow();
      const currentYear = now.getFullYear();
      const aprilEnd = new Date(currentYear, 3, 30, 23, 59, 59, 999);
      return now > aprilEnd ? currentYear + 1 : currentYear;
    };

    const challengeYear = getChallengeYear();
    const challengeStart = new Date(challengeYear, 3, 1, 0, 0, 0, 0);
    const challengeEnd = new Date(challengeYear, 3, 30, 23, 59, 59, 999);

    const getSundaysInApril = (year) => {
      const sundays = [];
      for (let day = 1; day <= 30; day += 1) {
        const date = new Date(year, 3, day);
        if (date.getDay() === 0) sundays.push(date);
      }
      return sundays;
    };

    const sundays = getSundaysInApril(challengeYear);

    const initProgressPoints = () => {
      const totalDuration = challengeEnd.getTime() - challengeStart.getTime();

      progressPointsElement.innerHTML = "";
      sundays.forEach((sunday) => {
        const elapsed = sunday.getTime() - challengeStart.getTime();
        const positionPercent = (elapsed / totalDuration) * 100;

        const winnerSlotLeft = document.createElement("span");
        winnerSlotLeft.className =
          "absolute top-1/2 h-14 w-14 rounded-full border-2 border-dashed border-primary/70 bg-gray-50 shadow-md dark:bg-gray-800";
        winnerSlotLeft.style.left = `${positionPercent}%`;
        winnerSlotLeft.style.transform = "translate(-90%, -180%)";
        winnerSlotLeft.style.zIndex = "2";
        winnerSlotLeft.title = "Winner headshot";
        winnerSlotLeft.innerHTML = `<img src="${questionMarkImage}" alt="Winner placeholder" class="h-full w-full rounded-full object-cover" />`;

        const winnerSlotRight = document.createElement("span");
        winnerSlotRight.className =
          "absolute top-1/2 h-14 w-14 rounded-full border-2 border-dashed border-primary/70 bg-gray-50 shadow-md dark:bg-gray-800";
        winnerSlotRight.style.left = `${positionPercent}%`;
        winnerSlotRight.style.transform = "translate(-10%, -180%)";
        winnerSlotRight.style.zIndex = "1";
        winnerSlotRight.title = "Winner headshot";
        winnerSlotRight.innerHTML = `<img src="${questionMarkImage}" alt="Winner placeholder" class="h-full w-full rounded-full object-cover" />`;

        const point = document.createElement("span");
        point.className =
          "absolute top-1/2 h-4 w-4 -translate-y-1/2 -translate-x-1/2 rounded-full border-2 border-primary bg-white dark:bg-gray-900";
        point.style.left = `${positionPercent}%`;
        point.title = sunday.toLocaleDateString(undefined, {
          month: "short",
          day: "numeric",
        });

        const label = document.createElement("span");
        label.className =
          "absolute top-6 -translate-x-1/2 text-[11px] font-medium text-gray-600 dark:text-gray-300";
        label.style.left = `${positionPercent}%`;
        label.textContent = sunday.toLocaleDateString(undefined, {
          month: "short",
          day: "numeric",
        });

        progressPointsElement.appendChild(winnerSlotRight);
        progressPointsElement.appendChild(winnerSlotLeft);
        progressPointsElement.appendChild(point);
        progressPointsElement.appendChild(label);
      });
    };

    const updateProgress = () => {
      const now = getNow();
      const totalDuration = challengeEnd.getTime() - challengeStart.getTime();
      const elapsed = now.getTime() - challengeStart.getTime();
      const clampedElapsed = Math.min(Math.max(elapsed, 0), totalDuration);
      const progress = (clampedElapsed / totalDuration) * 100;

      progressFillElement.style.width = `${progress}%`;

      const nextSunday = sundays.find((sunday) => now <= sunday);
      const msInDay = 1000 * 60 * 60 * 24;
      const rawDaysUntilNextSunday = nextSunday
        ? (nextSunday.getTime() - now.getTime()) / msInDay
        : 0;
      const daysUntilNextSunday = Math.max(0, Math.ceil(rawDaysUntilNextSunday));
      const isSundayMilestone = sundays.some(
        (sunday) =>
          sunday.getDate() === now.getDate() &&
          sunday.getMonth() === now.getMonth() &&
          sunday.getFullYear() === now.getFullYear(),
      );

      if (isSundayMilestone) {
        progressLabelTextElement.textContent = "";
        progressLabelHighlightElement.textContent = "New Winners Announced!";
      } else {
        progressLabelTextElement.textContent = "Two New Winners in ";
        progressLabelHighlightElement.textContent = `${daysUntilNextSunday} Days`;
      }
    };

    initProgressPoints();
    updateProgress();
    setInterval(() => {
      updateProgress();
    }, 1000);
  }
</script>
