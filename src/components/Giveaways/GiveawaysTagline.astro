<script>
  document.addEventListener("DOMContentLoaded", () => {
    const scrollLink = document.getElementById("official-entry-form-link");
    const target = document.getElementById("entry-form");

    if (!scrollLink || !target) {
      return;
    }

    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    );

    const easeInOutCubic = (progress) =>
      progress < 0.5
        ? 4 * progress * progress * progress
        : 1 - Math.pow(-2 * progress + 2, 3) / 2;

    scrollLink.addEventListener("click", (event) => {
      if (
        event.defaultPrevented ||
        event.button !== 0 ||
        event.metaKey ||
        event.ctrlKey ||
        event.shiftKey ||
        event.altKey
      ) {
        return;
      }

      event.preventDefault();

      if (prefersReducedMotion.matches) {
        target.scrollIntoView();
        history.pushState(null, "", "#entry-form");
        return;
      }

      const startY = window.scrollY;
      const targetY = target.getBoundingClientRect().top + startY;
      const distance = targetY - startY;
      const duration = Math.min(2200, Math.max(1200, Math.abs(distance) * 0.8));
      let startTime = null;

      const step = (timestamp) => {
        if (startTime === null) {
          startTime = timestamp;
        }

        const elapsed = timestamp - startTime;
        const progress = Math.min(elapsed / duration, 1);
        const easedProgress = easeInOutCubic(progress);

        window.scrollTo(0, startY + distance * easedProgress);

        if (progress < 1) {
          window.requestAnimationFrame(step);
          return;
        }

        history.pushState(null, "", "#entry-form");
      };

      window.requestAnimationFrame(step);
    });
  });
</script>
